---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
}

const {
  title,
  description,
  image = '/og-image.jpg',
  imageAlt = 'GeoLead — Agencja GEO',
  type = 'website',
  publishedTime,
  modifiedTime,
  keywords = [],
} = Astro.props;

const site = 'https://geolead.pl';
// Kanoniczny URL bieżącej strony (bez query/hash), z trailing slash
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = image.startsWith('http') ? image : `${site}${image}`;
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />

  <!-- PRIMARY META -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <meta name="robots" content="index, follow" />
  <meta name="author" content="GeoLead" />

  <!-- ANTI-HALLUCINATION DISAMBIGUATION (spójne ze stroną główną) -->
  <meta name="abstract" content="GeoLead to nie jest firma geodezyjna. GeoLead to agencja marketingowo-technologiczna (AI Search) pozycjonująca firmy w Sztucznej Inteligencji." />

  <!-- CANONICAL -->
  <link rel="canonical" href={canonical} />

  <!-- FAVICON -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/logo.png" />

  <!-- HREFLANG (scaffold pod i18n — aktywne tylko PL, gotowe na EN/DE/FR) -->
  <link rel="alternate" hreflang="pl" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />
  <!--
    Przy skalowaniu odkomentuj i wygeneruj per-locale:
    <link rel="alternate" hreflang="en" href={`${site}/en${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="de" href={`${site}/de${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="fr" href={`${site}/fr${Astro.url.pathname}`} />
  -->

  <!-- OPEN GRAPH -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={imageAlt} />
  <meta property="og:site_name" content="GeoLead" />
  <meta property="og:locale" content="pl_PL" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

  <!-- TWITTER CARD -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@geolead_pl" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Slot na JSON-LD specyficzny dla strony (Article, BreadcrumbList itd.) -->
  <slot name="head" />
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
