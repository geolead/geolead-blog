---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const terms = (await getCollection('slownik', ({ data }) => !data.draft))
  .sort((a, b) => a.data.term.localeCompare(b.data.term, 'pl'));

const breadcrumbs = [
  { name: 'Strona główna', href: 'https://geolead.pl/' },
  { name: 'Słownik GEO', href: '/slownik/' },
];
---

<BaseLayout
  title="Słownik GEO — pojęcia Generative Engine Optimization | GeoLead"
  description="Słownik kluczowych pojęć GEO: Entity Salience, RAG, Knowledge Graph, Vector Embedding i więcej. Zrozum, jak modele AI wybierają firmy do rekomendacji."
  keywords={['słownik GEO', 'Entity Salience', 'RAG', 'Knowledge Graph', 'Vector Embedding']}
>
  <!-- HEADER -->
  <div style="max-width:1080px;margin:0 auto;padding:4rem 1.5rem 2rem">
    <Breadcrumbs items={breadcrumbs} />
    <span class="article-kicker">Słownik</span>
    <h1 class="article-title" style="margin-bottom:0.8rem">Słownik GEO</h1>
    <p style="color:var(--text);font-size:1.05rem;max-width:560px;margin:0">
      Pojęcia, które decydują o tym, czy AI poleca Twoją firmę. Bez żargonu dla samego żargonu.
    </p>
  </div>

  <!-- GRID KAFELKOWY -->
  <section style="max-width:1080px;margin:0 auto;padding:0 1.5rem 5rem">
    {terms.length === 0 ? (
      <p style="text-align:center;color:var(--text-lo)">Hasła słownika w przygotowaniu.</p>
    ) : (
      <div class="sl-grid">
        {terms.map((t) => (
          <a href={`/slownik/${t.id.replace(/\.md$/, '')}/`} class="sl-card">
            <span class="sl-tag">{t.data.termCode}</span>
            <h2 class="sl-title">{t.data.term}</h2>
            <p class="sl-desc">{t.data.description.slice(0, 130)}…</p>
            <span class="sl-arrow">→</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <style>
    .sl-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    @media (max-width: 900px) {
      .sl-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 580px) {
      .sl-grid { grid-template-columns: 1fr; }
    }

    .sl-card {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      padding: 1.6rem 1.4rem 1.4rem;
      border-radius: 14px;
      border: 1px solid rgba(0,212,255,0.25);
      background: rgba(0,212,255,0.06);
      text-decoration: none;
      color: inherit;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      backdrop-filter: blur(6px);
    }

    .sl-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
      border-color: rgba(0,212,255,0.55);
    }

    .sl-tag {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(0,212,255,0.6);
    }

    .sl-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
      margin: 0;
      letter-spacing: -0.01em;
    }

    .sl-desc {
      font-size: 0.83rem;
      color: var(--text, rgba(255,255,255,0.6));
      line-height: 1.55;
      margin: 0;
      flex: 1;
    }

    .sl-arrow {
      font-size: 1rem;
      color: rgba(0,212,255,0.6);
      margin-top: 0.25rem;
      transition: transform 0.18s ease;
    }

    .sl-card:hover .sl-arrow {
      transform: translateX(4px);
    }
  </style>
</BaseLayout>
