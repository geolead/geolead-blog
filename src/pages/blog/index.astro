---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pillarLabel: Record<string, string> = {
  edukacja: 'Edukacja',
  branze: 'Branże',
  slownik: 'Słownik',
};

const pillarColor: Record<string, string> = {
  edukacja: 'rgba(0,212,255,0.15)',
  branze: 'rgba(224,64,251,0.15)',
  slownik: 'rgba(255,255,255,0.08)',
};

const pillarBorder: Record<string, string> = {
  edukacja: 'rgba(0,212,255,0.35)',
  branze: 'rgba(224,64,251,0.35)',
  slownik: 'rgba(255,255,255,0.15)',
};

const pillarText: Record<string, string> = {
  edukacja: '#00d4ff',
  branze: '#e040fb',
  slownik: 'rgba(255,255,255,0.5)',
};

const breadcrumbs = [
  { name: 'Strona główna', href: 'https://geolead.pl/' },
  { name: 'Blog', href: '/blog/' },
];
---

<BaseLayout
  title="Blog GeoLead — Wiedza o GEO i widoczności w AI | ChatGPT, Perplexity"
  description="Praktyczna wiedza o Generative Engine Optimization. Jak sprawić, by ChatGPT, Perplexity i Claude polecały Twoją firmę klientom B2B."
  keywords={['GEO', 'blog GEO', 'Generative Engine Optimization', 'AI Search', 'widoczność w ChatGPT']}
>
  <!-- HEADER -->
  <div style="max-width:1080px;margin:0 auto;padding:4rem 1.5rem 2rem">
    <Breadcrumbs items={breadcrumbs} />
    <span class="article-kicker">Blog</span>
    <h1 class="article-title" style="margin-bottom:0.8rem">Wiedza o GEO</h1>
    <p style="color:var(--text);font-size:1.05rem;max-width:560px;margin:0">
      Jak modele AI wybierają, którą firmę polecić — i jak sprawić, by wybierały Ciebie.
    </p>
  </div>

  <!-- GRID KAFELKOWY -->
  <section style="max-width:1080px;margin:0 auto;padding:0 1.5rem 5rem">
    {posts.length === 0 ? (
      <p style="text-align:center;color:var(--text-lo)">Pierwsze artykuły już w drodze.</p>
    ) : (
      <div class="bl-grid">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}/`}
            class="bl-card"
            style={`--card-bg:${pillarColor[post.data.pillar] ?? 'rgba(255,255,255,0.05)'};--card-border:${pillarBorder[post.data.pillar] ?? 'rgba(255,255,255,0.12)'};--tag-color:${pillarText[post.data.pillar] ?? 'rgba(255,255,255,0.4)'}`}
          >
            <span class="bl-tag">{pillarLabel[post.data.pillar] ?? post.data.pillar}</span>
            <h2 class="bl-title">{post.data.title}</h2>
            <p class="bl-desc">{post.data.description}</p>
            <span class="bl-arrow">→</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <style>
    .bl-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    @media (max-width: 900px) {
      .bl-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 580px) {
      .bl-grid { grid-template-columns: 1fr; }
    }

    .bl-card {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      padding: 1.6rem 1.4rem 1.4rem;
      border-radius: 14px;
      border: 1px solid var(--card-border, rgba(255,255,255,0.12));
      background: var(--card-bg, rgba(255,255,255,0.05));
      text-decoration: none;
      color: inherit;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      position: relative;
      backdrop-filter: blur(6px);
    }

    .bl-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
      border-color: rgba(224,64,251,0.55);
    }

    .bl-tag {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--tag-color, rgba(255,255,255,0.4));
    }

    .bl-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.35;
      margin: 0;
      letter-spacing: -0.01em;
    }

    .bl-desc {
      font-size: 0.83rem;
      color: var(--text, rgba(255,255,255,0.6));
      line-height: 1.55;
      margin: 0;
      flex: 1;
    }

    .bl-arrow {
      font-size: 1rem;
      color: rgba(224,64,251,0.7);
      margin-top: 0.25rem;
      transition: transform 0.18s ease;
    }

    .bl-card:hover .bl-arrow {
      transform: translateX(4px);
    }
  </style>
</BaseLayout>
